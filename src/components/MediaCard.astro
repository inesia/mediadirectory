---
import type { MediaOutlet } from '../lib/data';
import StatusBadge from './StatusBadge.astro';

interface Props {
  media: MediaOutlet;
}

const { media } = Astro.props;

/** Soft status tint — subtle marker so cards are easier to scan */
const statusSurface: Record<MediaOutlet['status'], string> = {
  verified: 'bg-white border-brand-dark/8',
  unverified: 'bg-zinc-100/90 border-brand-dark/10',
  review: 'bg-amber-50/90 border-amber-200/60',
  suspended: 'bg-rose-50/90 border-rose-200/50',
};

/** Display hostname only, e.g. https://www.kompas.com → kompas.com */
function displayDomain(domain: string) {
  try {
    const host = new URL(domain.startsWith('http') ? domain : `https://${domain}`).hostname;
    return host.replace(/^www\./, '');
  } catch {
    return domain.replace(/^https?:\/\//, '').replace(/^www\./, '').split('/')[0];
  }
}

const domainLabel = displayDomain(media.domain);
const avatarLabel = domainLabel.slice(0, 2).toUpperCase();
---

<article
  class:list={[
    'media-card group flex h-full flex-col border p-5 transition hover:border-brand-primary/25 hover:shadow-[0_12px_40px_-20px_rgba(76,29,149,0.35)]',
    statusSurface[media.status],
  ]}
  data-name={media.name.toLowerCase()}
  data-domain={domainLabel.toLowerCase()}
  data-type={media.type}
  data-province={media.address.province}
  data-status={media.status}
  data-categories={(media.categories || []).join(',').toLowerCase()}
>
  <div class="flex items-start justify-between gap-3">
    {media.logo ? (
      <div class="h-9 shrink-0 flex items-center">
        <img src={media.logo} alt={media.name} class="h-full w-auto max-w-[120px] object-contain object-left mix-blend-multiply" />
      </div>
    ) : (
      <div
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-primary/8 font-display text-sm font-bold text-brand-primary"
        aria-hidden="true"
      >
        {avatarLabel}
      </div>
    )}
    <StatusBadge status={media.status} />
  </div>

  <h3 class="mt-4 font-display text-lg font-bold tracking-tight text-brand-dark">
    <a href={`/directory/${media.slug}`} class="hover:text-brand-light">
      {domainLabel}
    </a>
  </h3>

  <p class="mt-1 flex-1 text-xs font-medium text-brand-dark/50">
    {media.type} · {media.address.city}, {media.address.province}
  </p>

  <div class="mt-5 border-t border-brand-dark/6 pt-4 text-right text-xs">
    <a
      href={`/directory/${media.slug}`}
      class="font-semibold text-brand-primary transition group-hover:text-brand-light"
    >
      Lihat profil →
    </a>
  </div>
</article>
