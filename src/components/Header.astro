---
const pathname = Astro.url.pathname;
const isHome = pathname === "/";

const links = [
  { href: "/", label: "Beranda" },
  { href: "/about", label: "Tentang Kami" },
  { href: "/directory", label: "List Media" },
];

const desktopLinks = links;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header
  id="main-header"
  data-is-home={isHome ? "true" : "false"}
  class:list={[
    "sticky top-0 z-50 transition-all duration-300",
    isHome
      ? "bg-transparent header-over-hero"
      : "border-b border-brand-dark/8 bg-white shadow-sm",
  ]}
>
  <div
    class="header-container mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 transition-all duration-300 sm:px-6 lg:px-8"
  >
    <a
      href="/"
      id="header-logo"
      class:list={[
        "shrink-0 font-display text-xl font-bold tracking-tight transition-colors duration-300 sm:text-2xl",
        isHome ? "text-white" : "text-brand-primary",
      ]}
    >
      mediadirectory
    </a>

    <div class="flex items-center gap-2 sm:gap-3">
      <nav class="hidden items-center gap-1 md:flex" aria-label="Navigasi utama">
        {
          desktopLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "header-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-300",
                isActive(link.href)
                  ? isHome
                    ? "bg-white/15 text-white"
                    : "bg-brand-primary/10 text-brand-primary"
                  : isHome
                    ? "text-white/80 hover:bg-white/10 hover:text-white"
                    : "text-brand-dark/70 hover:text-brand-primary",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Guest Login Button & Profile icon when logged in -->
      <div id="header-auth-group" class="flex items-center gap-1.5 sm:gap-2">
        <a
          href="/login"
          id="header-auth-login"
          class:list={[
            "header-auth-text inline-flex items-center justify-center rounded-full px-5 py-2 text-xs font-bold transition-all duration-300 shadow-sm hover:scale-[1.02] active:scale-[0.98]",
            isHome
              ? "bg-brand-accent text-brand-dark hover:bg-amber-400"
              : "bg-brand-primary text-white hover:bg-brand-primary/95",
          ]}
        >
          Login
        </a>
        <a
          href="/profile"
          id="header-auth-profile"
          class:list={[
            "header-auth-icon hidden h-9 w-9 items-center justify-center rounded-full transition duration-300",
            isHome
              ? "border border-white/30 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20"
              : "border border-brand-dark/12 bg-white text-brand-dark/70 shadow-sm hover:border-brand-primary/30 hover:text-brand-primary",
          ]}
          aria-label="Profil"
          title="Profil"
          hidden
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      </div>

      <button
        type="button"
        id="nav-toggle"
        class:list={[
          "inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-medium transition duration-300 md:hidden",
          isHome
            ? "border border-white/30 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20"
            : "border border-brand-dark/12 bg-white text-brand-dark shadow-sm hover:border-brand-primary/30",
        ]}
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Buka menu"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Solid white panel — always readable on mobile -->
  <div
    id="mobile-nav"
    class="hidden border-t border-brand-dark/8 bg-white shadow-md md:hidden"
    hidden
  >
    <nav
      class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 sm:px-6"
      aria-label="Menu"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-lg px-3 py-2.5 text-sm font-medium transition",
              isActive(link.href)
                ? "bg-brand-primary/10 text-brand-primary"
                : "text-brand-dark/80 hover:bg-brand-bg hover:text-brand-primary",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  const header = document.getElementById("main-header");
  const isHome = header?.getAttribute("data-is-home") === "true";

  const container = header?.querySelector(".header-container");
  const logo = document.getElementById("header-logo");
  const navLinks = document.querySelectorAll<HTMLElement>(".header-nav-link");
  const navClaim = document.getElementById("header-nav-claim");
  const menuBtn = document.getElementById("nav-toggle");
  const authLogin = document.getElementById("header-auth-login") as HTMLAnchorElement | null;
  const authProfile = document.getElementById("header-auth-profile") as HTMLAnchorElement | null;
  const authTexts = document.querySelectorAll<HTMLElement>(".header-auth-text");

  const profileHeroClasses = [
    "border-white/30",
    "bg-white/10",
    "text-white",
    "backdrop-blur-sm",
    "hover:bg-white/20",
  ];
  const profileSolidClasses = [
    "border-brand-dark/12",
    "bg-white",
    "text-brand-dark/70",
    "shadow-sm",
    "hover:border-brand-primary/30",
    "hover:text-brand-primary",
  ];

  function styleAuthChrome(solid: boolean) {
    authTexts.forEach((el) => {
      if (solid) {
        el.classList.remove("text-white/80", "hover:text-white");
        el.classList.add("text-brand-dark/70", "hover:text-brand-primary");
      } else {
        el.classList.remove("text-brand-dark/70", "hover:text-brand-primary");
        el.classList.add("text-white/80", "hover:text-white");
      }
    });

    if (!authProfile) return;
    if (solid) {
      authProfile.classList.remove(...profileHeroClasses);
      authProfile.classList.add(...profileSolidClasses);
    } else {
      authProfile.classList.remove(...profileSolidClasses);
      authProfile.classList.add(...profileHeroClasses);
    }
  }

  function getThreshold() {
    return Math.max(window.innerHeight - 80, 60);
  }

  function isScrolled() {
    return !isHome || window.scrollY > getThreshold();
  }

  function setSolidHeader() {
    if (!header) return;
    header.classList.remove("bg-transparent", "header-over-hero");
    header.classList.add(
      "border-b",
      "border-brand-dark/8",
      "bg-white",
      "shadow-sm",
    );
  }

  function setTransparentHeader() {
    if (!header || !isHome) return;
    header.classList.add("bg-transparent", "header-over-hero");
    header.classList.remove(
      "border-b",
      "border-brand-dark/8",
      "bg-white",
      "shadow-sm",
    );
  }

  function setLightChrome() {
    logo?.classList.remove("text-white");
    logo?.classList.add("text-brand-primary");

    navLinks.forEach((link) => {
      link.classList.remove(
        "text-white/80",
        "hover:bg-white/10",
        "hover:text-white",
        "bg-white/15",
        "text-white",
      );
      link.classList.add("text-brand-dark/70", "hover:text-brand-primary");
    });

    navClaim?.classList.remove(
      "border-white/40",
      "bg-white/10",
      "text-white",
      "backdrop-blur-sm",
      "hover:bg-white/20",
    );
    navClaim?.classList.add(
      "border-brand-accent",
      "bg-transparent",
      "text-brand-dark",
      "hover:bg-brand-accent/10",
    );

    menuBtn?.classList.remove(
      "border-white/30",
      "bg-white/10",
      "text-white",
      "backdrop-blur-sm",
      "hover:bg-white/20",
    );
    menuBtn?.classList.add(
      "border-brand-dark/12",
      "bg-white",
      "text-brand-dark",
      "shadow-sm",
      "hover:border-brand-primary/30",
    );

    styleAuthChrome(true);
  }

  function setHeroChrome() {
    logo?.classList.remove("text-brand-primary");
    logo?.classList.add("text-white");

    navLinks.forEach((link) => {
      link.classList.remove("text-brand-dark/70", "hover:text-brand-primary", "bg-brand-primary/10", "text-brand-primary");
      link.classList.add("text-white/80", "hover:bg-white/10", "hover:text-white");
    });

    navClaim?.classList.remove(
      "border-brand-accent",
      "bg-transparent",
      "text-brand-dark",
      "hover:bg-brand-accent/10",
    );
    navClaim?.classList.add(
      "border-white/40",
      "bg-white/10",
      "text-white",
      "backdrop-blur-sm",
      "hover:bg-white/20",
    );

    menuBtn?.classList.remove(
      "border-brand-dark/12",
      "bg-white",
      "text-brand-dark",
      "shadow-sm",
      "hover:border-brand-primary/30",
    );
    menuBtn?.classList.add(
      "border-white/30",
      "bg-white/10",
      "text-white",
      "backdrop-blur-sm",
      "hover:bg-white/20",
    );

    styleAuthChrome(false);
  }

  function syncHeader() {
    const menuOpen = toggle?.getAttribute("aria-expanded") === "true";
    const solid = !isHome || isScrolled() || menuOpen;

    if (solid) {
      setSolidHeader();
      setLightChrome();
      container?.classList.replace("py-4", "py-2.5");
    } else {
      setTransparentHeader();
      setHeroChrome();
      container?.classList.replace("py-2.5", "py-4");
    }
  }

  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    panel?.toggleAttribute("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    syncHeader();
  });

  if (isHome && header) {
    window.addEventListener("scroll", syncHeader, { passive: true });
    syncHeader();
  }

  // Guest: text Masuk · Logged-in: profile icon
  try {
    const auth = JSON.parse(localStorage.getItem("mdi_auth") || "null");
    const loggedIn = Boolean(auth?.email);

    if (loggedIn) {
      authLogin?.classList.add("hidden");
      authLogin?.setAttribute("hidden", "");
      authProfile?.classList.remove("hidden");
      authProfile?.classList.add("inline-flex");
      authProfile?.removeAttribute("hidden");
    } else {
      if (authLogin) {
        authLogin.href = `/login?next=${encodeURIComponent(window.location.pathname)}`;
      }
      authLogin?.classList.remove("hidden");
      authLogin?.removeAttribute("hidden");
      authProfile?.classList.add("hidden");
      authProfile?.classList.remove("inline-flex");
      authProfile?.setAttribute("hidden", "");
    }
  } catch {
    /* ignore */
  }
</script>
