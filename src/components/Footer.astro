---
const year = new Date().getFullYear();
---

<footer class="border-t border-brand-dark/8 bg-white">
  <div
    class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-2 lg:px-8 lg:py-12"
  >
    <div>
      <p class="font-display text-lg font-bold text-brand-primary">media directory</p>
      <p class="mt-2 max-w-xs text-sm leading-relaxed text-brand-dark/65">
        Registri tepercaya untuk ruang redaksi Indonesia — untuk editor, peneliti, dan publik.
      </p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-dark/45">Jelajahi</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="hover:text-brand-light" href="/directory">Lihat Direktori</a></li>
        <li><a class="hover:text-brand-light" href="/claim">Daftar & Klaim</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-brand-dark/8">
    <p class="mx-auto max-w-6xl px-4 py-4 text-center text-xs text-brand-dark/45 sm:px-6 lg:px-8">
      © {year} media directory
    </p>
  </div>
</footer>
