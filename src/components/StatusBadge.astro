---
interface Props {
  status: 'verified' | 'review' | 'suspended' | 'pending' | 'approved' | 'rejected';
  size?: 'sm' | 'md';
}

const { status, size = 'sm' } = Astro.props;

const labels: Record<Props['status'], string> = {
  verified: 'Terverifikasi',
  review: 'Ditinjau',
  suspended: 'Ditangguhkan',
  pending: 'Menunggu',
  approved: 'Disetujui',
  rejected: 'Ditolak',
};

const styles: Record<Props['status'], string> = {
  verified: 'bg-status-success/12 text-status-success ring-status-success/25',
  review: 'bg-status-pending/12 text-amber-700 ring-status-pending/30',
  suspended: 'bg-status-danger/12 text-status-danger ring-status-danger/25',
  pending: 'bg-status-pending/12 text-amber-700 ring-status-pending/30',
  approved: 'bg-status-success/12 text-status-success ring-status-success/25',
  rejected: 'bg-status-danger/12 text-status-danger ring-status-danger/25',
};

const sizeClass = size === 'md' ? 'px-2.5 py-1 text-xs' : 'px-2 py-0.5 text-[11px]';
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full font-semibold uppercase tracking-wide ring-1 ring-inset',
    sizeClass,
    styles[status],
  ]}
>
  <span class="h-1.5 w-1.5 rounded-full bg-current opacity-80" aria-hidden="true"></span>
  {labels[status]}
</span>
