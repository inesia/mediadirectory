---
import Layout from "../layouts/Layout.astro";
import MediaCard from "../components/MediaCard.astro";
import {
  getDirectoryStats,
  mediaOutlets,
  mediaTypes,
  provinces,
} from "../lib/data";

const stats = getDirectoryStats();
const featured = mediaOutlets
  .filter((m) => m.status === "verified")
  .slice(0, 3);
const latest = [...mediaOutlets]
  .sort((a, b) => {
    const dateA = a.registeredAt || "1970-01-01";
    const dateB = b.registeredAt || "1970-01-01";
    return dateB.localeCompare(dateA);
  })
  .slice(0, 4);
---

<Layout title="Beranda · Media Directory Indonesia">
  <!-- Hero — premium dark-gradient full screen -->
  <section
    class="hero-section relative -mt-[72px] flex min-h-screen flex-col items-center justify-center overflow-hidden pt-[72px]"
    aria-label="Hero"
  >
    <!-- === BACKGROUND LAYERS === -->
    <!-- Base deep gradient -->
    <div
      class="pointer-events-none absolute inset-0 hero-bg"
      aria-hidden="true"
    >
    </div>

    <!-- Dot-grid overlay -->
    <div
      class="pointer-events-none absolute inset-0 hero-dots"
      aria-hidden="true"
    >
    </div>

    <!-- Animated glow blobs -->
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="hero-blob hero-blob-1"></div>
      <div class="hero-blob hero-blob-2"></div>
      <div class="hero-blob hero-blob-3"></div>
      <div class="hero-blob hero-blob-4"></div>
    </div>

    <!-- === CONTENT === -->
    <div
      class="relative mx-auto flex w-full max-w-4xl flex-col items-center px-4 py-16 text-center sm:px-6 sm:py-20"
    >
      <!-- Pill badge -->
      <div
        class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-3.5 py-1.5 backdrop-blur-sm"
      >
        <span
          class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_6px_2px_rgba(52,211,153,0.5)]"
        ></span>
        <span
          class="text-[11px] font-semibold uppercase tracking-widest text-white/75"
          >Registri outlet berita</span
        >
      </div>

      <h1
        class="max-w-2xl font-display text-4xl font-extrabold leading-[1.1] tracking-tight text-white text-balance sm:text-5xl lg:text-6xl"
      >
        Cari media &amp; ruang<br class="hidden sm:block" />
        <span class="hero-gradient-text">redaksi Indonesia.</span>
      </h1>
      <p
        class="mt-5 max-w-xl text-sm leading-relaxed text-white/65 sm:text-base"
      >
        Temukan outlet berita, radio, TV, hingga podcast — filter berdasarkan
        jenis, lokasi, dan status verifikasi.
      </p>

      <!-- Search bar -->
      <form
        id="hero-search"
        action="/directory"
        method="get"
        class="mt-9 w-full max-w-[680px]"
      >
        <div
          class="flex flex-col gap-0 overflow-hidden rounded-2xl border border-white/12 bg-white/10 shadow-[0_24px_60px_-16px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:rounded-full sm:flex-row sm:items-stretch sm:divide-x sm:divide-white/10"
        >
          <!-- Query -->
          <label
            class="flex flex-1 items-center gap-2.5 px-4 py-3.5 text-left sm:px-5 sm:py-3"
          >
            <svg
              class="h-4 w-4 shrink-0 text-white/50"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="7"></circle><path
                d="M20 20l-3-3"
                stroke-linecap="round"></path>
            </svg>
            <span class="min-w-0 flex-1">
              <span class="sr-only">Cari media</span>
              <input
                type="search"
                name="q"
                placeholder="Cari nama media..."
                class="w-full bg-transparent text-xs font-semibold text-white outline-none placeholder:text-white/40"
              />
            </span>
          </label>

          <!-- Province -->
          <label
            class="flex flex-1 items-center gap-2.5 border-t border-white/10 px-4 py-3.5 text-left sm:border-t-0 sm:px-5 sm:py-3"
          >
            <svg
              class="h-4 w-4 shrink-0 text-white/50"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path
                d="M12 21s7-5.2 7-11a7 7 0 10-14 0c0 5.8 7 11 7 11z"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <circle cx="12" cy="10" r="2.5"></circle>
            </svg>
            <span class="min-w-0 flex-1">
              <span class="sr-only">Provinsi</span>
              <select
                name="province"
                class="w-full appearance-none bg-transparent text-xs font-semibold text-white outline-none cursor-pointer [&>option]:text-brand-dark [&>option]:bg-white"
              >
                <option value="">Semua lokasi</option>
                {provinces.map((p) => <option value={p}>{p}</option>)}
              </select>
            </span>
          </label>

          <!-- Type -->
          <label
            class="flex flex-1 items-center gap-2.5 border-t border-white/10 px-4 py-3.5 text-left sm:border-t-0 sm:px-5 sm:py-3"
          >
            <svg
              class="h-4 w-4 shrink-0 text-white/50"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect><path
                d="M3 10h18"
                stroke-linecap="round"></path>
            </svg>
            <span class="min-w-0 flex-1">
              <span class="sr-only">Jenis media</span>
              <select
                name="type"
                class="w-full appearance-none bg-transparent text-xs font-semibold text-white outline-none cursor-pointer [&>option]:text-brand-dark [&>option]:bg-white"
              >
                <option value="">Semua jenis</option>
                {mediaTypes.map((t) => <option value={t}>{t}</option>)}
              </select>
            </span>
          </label>

          <!-- Submit -->
          <div class="border-t border-white/10 p-2 sm:border-t-0 sm:p-1.5">
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-1.5 rounded-xl bg-brand-accent px-5 py-2.5 text-xs font-bold text-brand-dark transition hover:bg-amber-400 sm:w-auto sm:rounded-full sm:py-2"
            >
              <svg
                class="h-3.5 w-3.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="7"></circle><path
                  d="M20 20l-3-3"
                  stroke-linecap="round"></path>
              </svg>
              Cari
            </button>
          </div>
        </div>
      </form>

      <!-- Stats + standout CTA -->
      <div class="mt-8 flex flex-col items-center gap-4">
        <p class="text-[11px] font-semibold text-white/55">
          <span class="text-white/90">{stats.total}</span> media terdaftar &nbsp;·&nbsp;
          <span class="text-white/90">{stats.verified}</span> terverifikasi
        </p>
        <a
          href="/claim?tab=daftar"
          class="group inline-flex items-center gap-2 rounded-full bg-brand-accent px-6 py-3 text-sm font-bold text-brand-dark shadow-[0_8px_30px_-8px_rgba(245,158,11,0.7)] transition hover:bg-amber-400 hover:shadow-[0_12px_36px_-8px_rgba(245,158,11,0.85)] hover:scale-[1.02]"
        >
          <span
            class="flex h-5 w-5 items-center justify-center rounded-full bg-brand-dark/15 text-xs font-bold transition group-hover:bg-brand-dark/20"
            aria-hidden="true"
          >+</span>
          Daftarkan media Anda
        </a>
      </div>

      <!-- Floating type badges -->
      <div
        class="hero-badges pointer-events-none mt-10 flex flex-wrap justify-center gap-2 opacity-0"
        aria-hidden="true"
      >
        {
          ["Website", "TV", "Radio", "Podcast", "YouTube", "Newspaper"].map((t) => (
            <span class="rounded-full border border-white/10 bg-white/8 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white/50 backdrop-blur-sm">
              {t}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Benefits — for media owners -->
  <section
    class="relative overflow-hidden border-b border-brand-dark/6 bg-white"
    aria-labelledby="benefits-heading"
  >
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.35]"
      aria-hidden="true"
      style="background-image: radial-gradient(circle at 12% 20%, rgba(76,29,149,0.08), transparent 42%), radial-gradient(circle at 88% 70%, rgba(245,158,11,0.1), transparent 40%);"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent">
          Mengapa media directory
        </p>
        <h2
          id="benefits-heading"
          class="mt-3 font-display text-2xl font-extrabold tracking-tight text-brand-dark text-balance sm:text-3xl lg:text-4xl"
        >
          Bawa media Anda ke level berikutnya. Klaim kepemilikan sekarang.
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-brand-dark/65 sm:text-base">
          Bergabunglah dengan ratusan ekosistem media terpercaya. Amankan identitas
          brand Anda, dapatkan lencana verifikasi, dan buka akses ke peluang
          monetisasi serta kolaborasi eksklusif.
        </p>
      </div>

      <ul class="mt-12 grid gap-10 sm:mt-14 sm:grid-cols-2 lg:gap-x-10 lg:gap-y-12">
        {
          [
            {
              title: "Proteksi brand & anti-klaim palsu",
              points: [
                {
                  label: "Amankan aset digital Anda",
                  text: "Pastikan identitas dan nama media Anda tidak disalahgunakan atau diklaim oleh pihak yang tidak bertanggung jawab.",
                },
                {
                  label: "Hak akses penuh",
                  text: "Hanya pemilik sah yang terverifikasi yang dapat memperbarui informasi, mengganti logo, dan mengelola profil media.",
                },
              ],
              icon: "shield",
            },
            {
              title: "Lencana terverifikasi",
              points: [
                {
                  label: "Tingkatkan kredibilitas",
                  text: "Dapatkan lencana Approved setelah admin memverifikasi legalitas media Anda.",
                },
                {
                  label: "Magnet kepercayaan",
                  text: "Media terverifikasi lebih dilirik calon pengiklan, brand, dan agensi karena legalitasnya yang jelas.",
                },
              ],
              icon: "badge",
            },
            {
              title: "Visibilitas maksimal untuk calon pengiklan",
              points: [
                {
                  label: "Masuk radar agensi & brand",
                  text: "Profil Anda masuk katalog pencarian utama yang diakses perusahaan pencari mitra publikasi.",
                },
                {
                  label: "Statistik terpusat",
                  text: "Tampilkan metrik terbaik langsung ke calon klien tanpa mengirim media kit berkali-kali.",
                },
              ],
              icon: "chart",
            },
            {
              title: "Monetisasi & kampanye eksklusif",
              points: [
                {
                  label: "Undangan kampanye langsung",
                  text: "Dapatkan tawaran sponsored post, content placement, atau iklan berdasarkan kategori media Anda.",
                },
                {
                  label: "Komunitas & insight",
                  text: "Akses tren industri media terbaru dan peluang kolaborasi antar pemilik media di dalam platform.",
                },
              ],
              icon: "spark",
            },
          ].map((item) => (
            <li class="benefit-item group">
              <div class="flex items-start gap-4">
                <span
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-primary/8 text-brand-primary transition group-hover:bg-brand-accent/15 group-hover:text-amber-700"
                  aria-hidden="true"
                >
                  {item.icon === "shield" && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  )}
                  {item.icon === "badge" && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3l2.1 4.3 4.7.7-3.4 3.3.8 4.7L12 14.3 7.8 16l.8-4.7L5.2 8l4.7-.7L12 3z" stroke-linecap="round" stroke-linejoin="round"></path>
                      <circle cx="12" cy="12" r="9"></circle>
                    </svg>
                  )}
                  {item.icon === "chart" && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 19V5M4 19h16" stroke-linecap="round"></path>
                      <path d="M8 16v-5M12 16V8M16 16v-8" stroke-linecap="round"></path>
                    </svg>
                  )}
                  {item.icon === "spark" && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8" stroke-linecap="round"></path>
                    </svg>
                  )}
                </span>
                <div class="min-w-0 flex-1">
                  <h3 class="font-display text-lg font-bold tracking-tight text-brand-dark">
                    {item.title}
                  </h3>
                  <ul class="mt-3 space-y-3">
                    {item.points.map((point) => (
                      <li>
                        <p class="text-sm font-semibold text-brand-dark/85">{point.label}</p>
                        <p class="mt-0.5 text-sm leading-relaxed text-brand-dark/60">{point.text}</p>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-3 sm:mt-14">
        <a
          href="/claim?tab=klaim"
          class="inline-flex items-center rounded-full bg-brand-accent px-6 py-3 text-sm font-bold text-brand-dark shadow-[0_8px_24px_-8px_rgba(245,158,11,0.65)] transition hover:bg-amber-400"
        >
          Klaim kepemilikan sekarang
        </a>
        <a
          href="/claim?tab=daftar"
          class="inline-flex items-center rounded-full border border-brand-dark/12 px-5 py-2.5 text-sm font-semibold text-brand-dark transition hover:border-brand-primary/30 hover:text-brand-primary"
        >
          Daftarkan media
        </a>
      </div>
    </div>
  </section>

  <!-- Cara kerja -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="font-display text-xl font-extrabold tracking-tight sm:text-2xl text-brand-dark"
      >
        Cara Kerja
      </h2>
      <p class="mt-1 text-xs text-brand-dark/60">
        Sederhana, berverifikasi, dan transparan untuk publik.
      </p>
    </div>
    <ol class="mt-6 grid gap-4 grid-cols-1 sm:grid-cols-3">
      {
        [
          {
            step: "01",
            title: "Cari",
            body: "Ketik nama, pilih lokasi, atau filter jenis media.",
          },
          {
            step: "02",
            title: "Jelajahi",
            body: "Lihat profil outlet beserta status verifikasinya.",
          },
          {
            step: "03",
            title: "Klaim",
            body: "Ajukan kepemilikan listing untuk ruang redaksi Anda.",
          },
        ].map((item) => (
          <li class="rounded-xl border border-brand-dark/6 bg-white/60 p-4 text-center">
            <span class="font-display text-xs font-bold text-brand-accent">
              {item.step}
            </span>
            <h3 class="mt-1 font-display text-sm font-bold text-brand-dark">
              {item.title}
            </h3>
            <p class="mt-1 text-xs leading-relaxed text-brand-dark/65">
              {item.body}
            </p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Featured -->
  <section class="border-y border-brand-dark/6 bg-white py-10 sm:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <h2
            class="font-display text-xl font-extrabold tracking-tight sm:text-2xl text-brand-dark"
          >
            Media Terverifikasi Unggulan
          </h2>
          <p class="mt-1 text-xs text-brand-dark/60">
            Contoh ruang redaksi nasional terkemuka yang sudah memiliki badge
            Terverifikasi.
          </p>
        </div>
        <a
          href="/directory?status=verified"
          class="text-xs font-semibold text-brand-primary hover:text-brand-light transition"
        >
          Lihat semua →
        </a>
      </div>

      <div class="mt-6 grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {featured.slice(0, 3).map((media) => <MediaCard media={media} />)}
      </div>
    </div>
  </section>

  <!-- Media Terbaru -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div
      class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <h2
          class="font-display text-xl font-extrabold tracking-tight sm:text-2xl text-brand-dark"
        >
          Media Terbaru
        </h2>
        <p class="mt-1 text-xs text-brand-dark/60">
          Redaksi dan outlet media yang baru saja ditambahkan ke dalam
          direktori.
        </p>
      </div>
      <a
        href="/directory"
        class="text-xs font-semibold text-brand-primary hover:text-brand-light transition"
      >
        Lihat semua →
      </a>
    </div>

    <div class="mt-6 grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
      {latest.map((media) => <MediaCard media={media} />)}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-12 pt-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col items-start gap-4 rounded-2xl bg-brand-primary px-6 py-6 text-white sm:flex-row sm:items-center sm:justify-between sm:px-8 sm:py-8"
    >
      <div class="max-w-xl">
        <h2
          class="font-display text-lg font-bold tracking-tight sm:text-xl text-white"
        >
          Media Anda belum ada di sini?
        </h2>
        <p class="mt-1 text-xs text-white/75 sm:text-sm">
          Klaim atau daftarkan listing agar publik bisa menemukan ruang redaksi
          Anda secara langsung.
        </p>
      </div>
      <a
        href="/claim"
        class="inline-flex shrink-0 items-center justify-center rounded-full bg-brand-accent px-5 py-2.5 text-xs font-semibold text-brand-dark transition hover:bg-amber-400"
      >
        Mulai Klaim
      </a>
    </div>
  </section>
</Layout>
