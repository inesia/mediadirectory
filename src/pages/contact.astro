---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hubungi Kami" description="Hubungi Kami - Media Directory Indonesia">
  <section class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="border border-brand-dark/8 bg-white p-6 sm:p-10 rounded-2xl shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent">Bantuan</p>
      <h1 class="mt-2 font-display text-3xl font-extrabold tracking-tight text-brand-dark sm:text-4xl">
        Hubungi Kami
      </h1>
      <p class="mt-4 text-base leading-relaxed text-brand-dark/70">
        Apakah Anda memiliki pertanyaan mengenai verifikasi media, pengajuan listing, atau peluang kerja sama? Hubungi tim kami melalui formulir atau kontak di bawah ini.
      </p>
      
      <div class="mt-8 space-y-6">
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="p-4 rounded-xl bg-brand-bg border border-brand-dark/6">
            <h3 class="font-bold text-brand-dark">Email Dukungan</h3>
            <p class="text-sm text-brand-dark/70 mt-1">support@mediadirectory.id</p>
          </div>
          <div class="p-4 rounded-xl bg-brand-bg border border-brand-dark/6">
            <h3 class="font-bold text-brand-dark">Kerja Sama & Iklan</h3>
            <p class="text-sm text-brand-dark/70 mt-1">partnership@mediadirectory.id</p>
          </div>
        </div>

        <form class="space-y-4 mt-8" onsubmit="event.preventDefault(); alert('Pesan berhasil terkirim!');">
          <div>
            <label class="block text-sm font-semibold text-brand-dark mb-1">Nama Lengkap</label>
            <input type="text" placeholder="Nama Anda" class="w-full rounded-lg border border-brand-dark/12 bg-white px-3 py-2.5 text-sm outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20" required />
          </div>
          <div>
            <label class="block text-sm font-semibold text-brand-dark mb-1">Alamat Email</label>
            <input type="email" placeholder="anda@email.com" class="w-full rounded-lg border border-brand-dark/12 bg-white px-3 py-2.5 text-sm outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20" required />
          </div>
          <div>
            <label class="block text-sm font-semibold text-brand-dark mb-1">Pesan</label>
            <textarea placeholder="Tuliskan pesan atau pertanyaan Anda di sini..." rows="4" class="w-full rounded-lg border border-brand-dark/12 bg-white px-3 py-2.5 text-sm outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20" required></textarea>
          </div>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-brand-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-light">
            Kirim Pesan
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
