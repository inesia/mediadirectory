---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Profil" description="Kelola akun dan pengaturan profil Anda di media directory.">
  <section class="border-b border-brand-dark/6 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent">Akun</p>
      <h1 class="mt-2 font-display text-3xl font-bold tracking-tight sm:text-4xl">Profil</h1>
      <p class="mt-2 text-sm text-brand-dark/65 sm:text-base">
        Kelola informasi akun dan akses cepat ke pengajuan Anda.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
    <div id="profile-guest" class="hidden border border-brand-dark/8 bg-white p-6 sm:p-8" hidden>
      <p class="text-sm text-brand-dark/65">Anda belum masuk.</p>
      <a
        href="/login?next=/profile"
        class="mt-4 inline-flex rounded-lg bg-brand-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-light"
      >
        Masuk
      </a>
    </div>

    <div id="profile-content" class="space-y-6">
      <div class="border border-brand-dark/8 bg-white p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <div
            id="profile-avatar"
            class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-brand-primary font-display text-lg font-bold text-white"
            aria-hidden="true"
          >
            --
          </div>
          <div class="min-w-0 flex-1">
            <h2 id="profile-name" class="font-display text-xl font-bold tracking-tight">—</h2>
            <p id="profile-email" class="mt-1 text-sm text-brand-dark/60">—</p>
            <p id="profile-since" class="mt-2 text-xs text-brand-dark/45"></p>
          </div>
        </div>
      </div>

      <nav class="border border-brand-dark/8 bg-white" aria-label="Menu profil">
        <p class="border-b border-brand-dark/6 px-5 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-brand-dark/45">
          Menu
        </p>
        <ul class="divide-y divide-brand-dark/6">
          <li>
            <a
              href="/pengajuan"
              class="flex items-center justify-between px-5 py-4 text-sm font-medium text-brand-dark transition hover:bg-brand-bg hover:text-brand-primary"
            >
              Pengajuan Saya
              <span class="text-brand-dark/35" aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a
              href="/claim?tab=daftar"
              class="flex items-center justify-between px-5 py-4 text-sm font-medium text-brand-dark transition hover:bg-brand-bg hover:text-brand-primary"
            >
              Daftar Media
              <span class="text-brand-dark/35" aria-hidden="true">→</span>
            </a>
          </li>
          <li>
            <a
              href="/claim?tab=klaim"
              class="flex items-center justify-between px-5 py-4 text-sm font-medium text-brand-dark transition hover:bg-brand-bg hover:text-brand-primary"
            >
              Klaim Media
              <span class="text-brand-dark/35" aria-hidden="true">→</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="border border-brand-dark/8 bg-white p-6 sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-dark/45">Sesi</p>
        <button
          type="button"
          id="profile-logout"
          class="mt-4 inline-flex w-full items-center justify-center rounded-lg border border-status-danger/30 px-5 py-3 text-sm font-semibold text-status-danger transition hover:bg-status-danger/5 sm:w-auto"
        >
          Keluar
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  const AUTH_KEY = 'mdi_auth';

  const guest = document.getElementById('profile-guest');
  const content = document.getElementById('profile-content');
  const avatar = document.getElementById('profile-avatar');
  const nameEl = document.getElementById('profile-name');
  const emailEl = document.getElementById('profile-email');
  const sinceEl = document.getElementById('profile-since');
  const logoutBtn = document.getElementById('profile-logout');

  function initials(name: string) {
    const parts = name.trim().split(/\s+/).filter(Boolean);
    if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
    return (parts[0]?.slice(0, 2) || 'MD').toUpperCase();
  }

  try {
    const auth = JSON.parse(localStorage.getItem(AUTH_KEY) || 'null');

    if (!auth?.email) {
      guest?.classList.remove('hidden');
      guest?.removeAttribute('hidden');
      content?.classList.add('hidden');
      content?.setAttribute('hidden', '');
    } else {
      guest?.classList.add('hidden');
      guest?.setAttribute('hidden', '');
      content?.classList.remove('hidden');
      content?.removeAttribute('hidden');

      const name = auth.name || 'Pengguna';
      const email = auth.email;

      if (avatar) avatar.textContent = initials(name);
      if (nameEl) nameEl.textContent = name;
      if (emailEl) emailEl.textContent = email;
      if (sinceEl && auth.loggedInAt) {
        sinceEl.textContent = `Masuk sejak ${new Date(auth.loggedInAt).toLocaleDateString('id-ID', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })}`;
      }
    }
  } catch {
    guest?.classList.remove('hidden');
    guest?.removeAttribute('hidden');
    content?.classList.add('hidden');
    content?.setAttribute('hidden', '');
  }

  logoutBtn?.addEventListener('click', () => {
    localStorage.removeItem(AUTH_KEY);
    window.location.href = '/';
  });
</script>
