---
import Layout from '../../layouts/Layout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { getMediaBySlug, mediaOutlets } from '../../lib/data';

export function getStaticPaths() {
  return mediaOutlets.map((media) => ({
    params: { slug: media.slug },
  }));
}

const { slug } = Astro.params;
const media = getMediaBySlug(slug!);

if (!media) {
  return Astro.redirect('/directory');
}

const related = mediaOutlets
  .filter(
    (item) =>
      item.id !== media.id &&
      (item.type === media.type || item.address.province === media.address.province),
  )
  .slice(0, 3);

const socialEntries = Object.entries(media.social).filter(([, url]) => Boolean(url)) as [
  string,
  string,
][];

const socialLabels: Record<string, string> = {
  facebook: 'Facebook',
  instagram: 'Instagram',
  tiktok: 'TikTok',
  youtube: 'YouTube',
  x: 'X',
  threads: 'Threads',
  linkedin: 'LinkedIn',
  telegram: 'Telegram',
};

const gallery = media.images?.filter(Boolean) ?? [];
---

<Layout title={media.name} description={media.description}>
  <section class="border-b border-brand-dark/6 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
      <a
        href="/directory"
        class="text-sm font-medium text-brand-primary hover:text-brand-light"
      >
        ← Kembali ke direktori
      </a>

      <div class="mt-6 flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex gap-4">
          {
            media.logo ? (
              <img
                src={media.logo}
                alt={`Logo ${media.name}`}
                class="h-16 w-16 shrink-0 rounded-2xl object-cover ring-1 ring-brand-dark/10 sm:h-20 sm:w-20"
              />
            ) : (
              <div
                class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand-primary font-display text-xl font-bold text-white sm:h-20 sm:w-20 sm:text-2xl"
                aria-hidden="true"
              >
                {media.name.slice(0, 2).toUpperCase()}
              </div>
            )
          }
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
                {media.name}
              </h1>
              <StatusBadge status={media.status} size="md" />
            </div>
            <p class="mt-2 text-sm text-brand-dark/55">
              {media.type} · {media.address.city}, {media.address.province}
              {media.founded ? ` · Didirikan ${media.founded}` : ''}
            </p>
            {
              media.companyName && (
                <p class="mt-1 text-sm text-brand-dark/50">{media.companyName}</p>
              )
            }
            <div class="mt-3 flex flex-wrap gap-1.5">
              {
                (media.categories || []).map((cat) => (
                  <span class="rounded-md bg-brand-bg px-2.5 py-1 text-xs font-medium text-brand-dark/60">
                    {cat}
                  </span>
                ))
              }
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row lg:flex-col lg:items-stretch">
          <a
            href={media.domain}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg border border-brand-dark/12 bg-white px-4 py-2.5 text-sm font-semibold text-brand-dark transition hover:border-brand-primary/30 hover:text-brand-primary"
          >
            Kunjungi situs
          </a>
          <a
            href={`/claim?tab=klaim&media=${media.slug}`}
            class="inline-flex items-center justify-center rounded-lg bg-brand-accent px-4 py-2.5 text-sm font-semibold text-brand-dark transition hover:bg-amber-400"
          >
            Klaim media ini
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:grid lg:grid-cols-[1.4fr_0.6fr] lg:gap-10 lg:px-8 lg:py-12">
    <div class="space-y-8">
      <!-- Galeri / Screenshot -->
      <div>
        <h2 class="font-display text-xl font-bold">Galeri</h2>
        {
          gallery.length > 0 ? (
            <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3">
              {gallery.map((src, i) => (
                <img
                  src={src}
                  alt={`Screenshot ${media.name} ${i + 1}`}
                  class="aspect-video w-full rounded-lg object-cover ring-1 ring-brand-dark/8"
                />
              ))}
            </div>
          ) : (
            <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3">
              {[0, 1, 2].map((i) => (
                <div
                  class="flex aspect-video w-full items-center justify-center rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-accent/10 text-xs font-medium text-brand-dark/40 ring-1 ring-brand-dark/8"
                  aria-hidden="true"
                >
                  Screenshot {i + 1}
                </div>
              ))}
            </div>
          )
        }
      </div>

      <!-- Tentang -->
      <div>
        <h2 class="font-display text-xl font-bold">Tentang</h2>
        <p class="mt-3 text-sm leading-relaxed text-brand-dark/75 sm:text-base">
          {media.description}
        </p>
      </div>

      <!-- Informasi media -->
      <dl class="grid gap-4 sm:grid-cols-2">
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Jenis Media
          </dt>
          <dd class="mt-1 text-sm font-medium">{media.type}</dd>
        </div>
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Status
          </dt>
          <dd class="mt-1"><StatusBadge status={media.status} /></dd>
        </div>
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Nama Perusahaan
          </dt>
          <dd class="mt-1 text-sm font-medium">{media.companyName || '—'}</dd>
        </div>
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Tahun Berdiri
          </dt>
          <dd class="mt-1 text-sm font-medium">{media.founded || '—'}</dd>
        </div>
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Domain / URL
          </dt>
          <dd class="mt-1 truncate text-sm font-medium text-brand-primary">
            <a href={media.domain} target="_blank" rel="noopener noreferrer">{media.domain}</a>
          </dd>
        </div>
        <div class="border border-brand-dark/8 bg-white p-4">
          <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
            Verifikasi
          </dt>
          <dd class="mt-1 text-sm font-medium">
            {
              media.verifiedAt
                ? `Terverifikasi pada ${new Date(media.verifiedAt).toLocaleDateString('id-ID', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric',
                  })}`
                : 'Belum terverifikasi'
            }
          </dd>
        </div>
      </dl>

      <!-- Kontak -->
      <div class="border border-brand-dark/8 bg-white p-5">
        <h3 class="font-display text-base font-bold">Kontak</h3>
        <dl class="mt-3 grid gap-3 sm:grid-cols-2">
          <div>
            <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
              Telepon / WhatsApp
            </dt>
            <dd class="mt-1 text-sm font-medium">{media.contact.phone}</dd>
          </div>
          <div>
            <dt class="text-[11px] font-semibold uppercase tracking-wide text-brand-dark/45">
              Email Redaksi
            </dt>
            <dd class="mt-1 text-sm font-medium text-brand-primary">{media.contact.email}</dd>
          </div>
        </dl>
      </div>

      <!-- Alamat -->
      <div class="border border-brand-dark/8 bg-white p-5">
        <h3 class="font-display text-base font-bold">Alamat</h3>
        <p class="mt-2 text-sm leading-relaxed text-brand-dark/70">
          {media.address.street}<br />
          Kec. {media.address.district}, {media.address.city}<br />
          {media.address.province}
        </p>
      </div>

      <!-- Media sosial -->
      {
        socialEntries.length > 0 && (
          <div class="border border-brand-dark/8 bg-white p-5">
            <h3 class="font-display text-base font-bold">Media Sosial</h3>
            <ul class="mt-3 flex flex-wrap gap-2">
              {socialEntries.map(([key, url]) => (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex rounded-full border border-brand-dark/12 px-3 py-1.5 text-xs font-semibold text-brand-dark/70 transition hover:border-brand-primary/30 hover:text-brand-primary"
                  >
                    {socialLabels[key] || key}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <aside class="mt-10 lg:mt-0">
      <h2 class="font-display text-xl font-bold">Media terkait</h2>
      <ul class="mt-4 space-y-3">
        {
          related.map((item) => (
            <li>
              <a
                href={`/directory/${item.slug}`}
                class="flex items-center justify-between gap-3 border border-brand-dark/8 bg-white p-4 transition hover:border-brand-primary/25"
              >
                <span>
                  <span class="block font-semibold">{item.name}</span>
                  <span class="mt-0.5 block text-xs text-brand-dark/50">
                    {item.type} · {item.address.city}
                  </span>
                </span>
                <StatusBadge status={item.status} />
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>
</Layout>
